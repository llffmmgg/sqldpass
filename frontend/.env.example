NEXT_PUBLIC_API_URL=http://localhost:8080
# AdSense 오른쪽 사이드 300x600 광고 슬롯 ID (비워두면 광고 미렌더)
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=

# PortOne V2 — 결제 페이지 (/checkout) 에서 사용.
# store-{uuid} : PortOne 어드민 → 상점 → Store ID
# channel-key  : PortOne 어드민 → 결제 연동 → 채널 → 채널 키 (PG 별로 1개)
NEXT_PUBLIC_PORTONE_STORE_ID=
# 카카오페이(간편결제) 채널 키
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_KAKAOPAY=
# KG이니시스(INIpay) 일반결제 채널 키 — 테스트는 INIpayTest MID 로 발급
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_INICIS=
# (deprecated) 단일 채널 키 — 새 변수 누락 시 카카오페이로 fallback. 다음 PR에서 제거 예정.
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=
