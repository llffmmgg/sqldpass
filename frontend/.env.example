NEXT_PUBLIC_API_URL=http://localhost:8080
# AdSense 오른쪽 사이드 300x600 광고 슬롯 ID (비워두면 광고 미렌더)
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=

# ──────────────────────────────────────────────────────────
# 고정 크기 배너 광고 슬롯 (AdSense 대시보드에서 위치별 발급)
# 빈 값이면 해당 위치 광고 미렌더 — 발급 전 배포 안전.
# 데스크톱/모바일 분리 발급으로 위치별 성과(CTR/RPM) 추적.
# ──────────────────────────────────────────────────────────

# /dashboard 요약 카드 아래 (데스크톱 728×90 / 모바일 320×100)
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD_DESKTOP=
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD_MOBILE=

# /wrong-answers 카드 리스트 위 (데스크톱 336×280 / 모바일 320×100)
NEXT_PUBLIC_ADSENSE_SLOT_WRONG_ANSWERS_DESKTOP=
NEXT_PUBLIC_ADSENSE_SLOT_WRONG_ANSWERS_MOBILE=

# /blog/[slug] 본문 도입부 (데스크톱 728×90 / 모바일 320×100)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_TOP_DESKTOP=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_TOP_MOBILE=

# /blog/[slug] 본문 끝 (데스크톱 336×280 / 모바일 320×100)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_BOTTOM_DESKTOP=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_BOTTOM_MOBILE=
