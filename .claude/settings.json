{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$(git -c safe.directory=C:/Users/admin/Desktop/sqldpass/sqldpass rev-parse --show-toplevel)/scripts/hooks/pre-tool-use-guard.ps1\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "^(Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$(git -c safe.directory=C:/Users/admin/Desktop/sqldpass/sqldpass rev-parse --show-toplevel)/scripts/hooks/tdd-guard.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$(git -c safe.directory=C:/Users/admin/Desktop/sqldpass/sqldpass rev-parse --show-toplevel)/scripts/hooks/lint-build-test.ps1\"",
            "timeout": 1200
          }
        ]
      }
    ]
  }
}
