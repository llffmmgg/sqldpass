node_modules/

# Android Studio / Gradle
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/app/release/
android/captures/
android/local.properties
android/gradle.properties.local

# Signing — keystores never go in git
*.keystore
*.jks
keystore.properties

# Gradle wrapper jar 는 git 에 포함되어야 함 (다른 머신에서 ./gradlew 실행 가능 보장)
# 루트 .gitignore 의 `*.jar` 룰이 wrapper 까지 차단하므로 negate 로 복구.
!android/gradle/wrapper/gradle-wrapper.jar

# Firebase / Play services configs (contain project IDs/keys)
android/app/google-services.json
android/app/google-services-debug.json

# Capacitor sync artefacts
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# Misc
.DS_Store
*.log
