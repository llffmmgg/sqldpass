<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!--
			User ID — 백엔드가 발급한 멤버 식별자(JWT 의 sub)를 모든 API 요청에 동반.
			Linked to user, used only for app functionality.
		-->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeUserID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!--
			Email Address / Name — Apple/Google 최초 로그인 시 사용자 식별·닉네임 초기화에 사용.
			저장은 백엔드 책임이며 앱은 표시 외 용도로 사용하지 않는다.
		-->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeName</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!--
			Product Interaction — 풀이/답안/북마크/오답 등 학습 진행 데이터.
			Linked to user, used only for app functionality (학습 기록·점수 추적).
		-->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!--
			Purchase History — Apple StoreKit 영수증/transaction 정보.
			Linked to user, used for app functionality (entitlement 부여) and analytics 차단.
		-->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePurchaseHistory</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>
	<!--
		Required Reason API 사용 사유 선언.
		현재 사용 중인 API 군 + 사유 코드. 필요한 경우 빌드 시 추가.
		- File timestamp API: 미사용 (네이티브에서 직접 사용 안 함)
		- User defaults API: SwiftData/UserDefaults 미사용. Keychain 만 사용.
		- 그 외 카테고리: 해당 사항 없음.
	-->
	<key>NSPrivacyAccessedAPITypes</key>
	<array/>
</dict>
</plist>
