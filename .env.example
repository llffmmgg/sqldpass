# ============================================================
# sqldpass 운영 환경변수 (.env)
# ============================================================
#
# 이 파일을 복사하여 .env로 이름 변경 후 실제 값을 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요.
#
# 사용법:
#   cp .env.example .env
#   vim .env  # 실제 값 입력
# ============================================================

# === 데이터베이스 설정 ===
MYSQL_DATABASE=sqldpass                  # 생성될 데이터베이스 이름
MYSQL_ROOT_PASSWORD=                     # MySQL root 비밀번호 (강력한 비밀번호 사용)
MYSQL_USER=sqldpass_app                  # 앱 전용 MySQL 사용자 (root 아님)
MYSQL_PASSWORD=                          # 앱 전용 MySQL 비밀번호

# === 애플리케이션 설정 ===
APP_PORT=8080                            # 호스트에 노출할 포트 (기본값 8080)

# === JWT 인증 ===
JWT_SECRET=                              # JWT 서명 키 (최소 32자 이상의 랜덤 문자열)

# === 관리자 계정 ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=                     # BCrypt 해시값 (htpasswd -nbBC 10 "" 비밀번호 | cut -d: -f2)

# === Google OAuth ===
GOOGLE_OAUTH_CLIENT_ID=                  # Google Cloud Console에서 발급
GOOGLE_OAUTH_CLIENT_SECRET=              # Google Cloud Console에서 발급

# === AI API 키 ===
ANTHROPIC_API_KEY=                       # Anthropic API 키 (Claude)
GOOGLE_GENAI_API_KEY=                    # Google GenAI API 키 (Gemini)
OPENAI_API_KEY=                          # OpenAI API 키 (GPT)
